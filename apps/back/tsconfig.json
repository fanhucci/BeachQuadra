{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "./",        // A "caixa" agora é a pasta do back-end toda
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../shared/src/*"] 
    }
  },
  "include": [
    "src/**/*", 
    "../../shared/src/**/*" // Você avisa explicitamente para incluir o shared
  ]
}